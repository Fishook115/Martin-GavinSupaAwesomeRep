; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

curved_lines_2d/stroke_color=Color(0, 0, 0, 1)
curved_lines_2d/fill_color=Color(1, 0.988098, 0.238281, 0.376471)

[application]

config/name="Gavin & Martin Gamejam Project"
run/main_scene="uid://h1vaeo40871w"
config/features=PackedStringArray("4.4", "Forward Plus")

[autoload]

Global="*res://scripts/global.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2

[editor_plugins]

enabled=PackedStringArray("res://addons/curved_lines_2d/plugin.cfg")

[file_customization]

folder_colors={
"res://fonts/": "teal",
"res://materials/": "purple",
"res://music/": "green",
"res://scenes/": "blue",
"res://scripts/": "red",
"res://sfx/": "orange",
"res://shaders/": "pink"
}

